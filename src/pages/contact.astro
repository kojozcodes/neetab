---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact | Neetab"
  description="Get in touch with the Neetab team. Questions, feedback, tool requests - we read every message."
  path="/contact"
>
  <Header slot="header" />

  <div class="max-w-xl mx-auto px-5 py-10 animate-fade-in">
    <h1 class="font-display text-2xl sm:text-3xl font-bold tracking-tight text-surface-900 dark:text-surface-100 mb-3">
      Contact
    </h1>
    <p class="text-sm text-surface-500 dark:text-surface-400 mb-10">
      We read every message. Expect a reply within 1-2 business days.
    </p>

    <div class="space-y-4">
      <div class="flex items-start gap-4 px-5 py-4 rounded-xl border border-surface-200 dark:border-surface-800 bg-surface-50 dark:bg-surface-900">
        <span class="text-xl mt-0.5">✉️</span>
        <div>
          <p class="text-xs font-bold text-surface-700 dark:text-surface-300 mb-1">General enquiries</p>
          <a href="mailto:hello@neetab.com" class="text-sm text-brand-500 font-medium hover:underline">hello@neetab.com</a>
          <p class="text-xs text-surface-400 mt-1">Tool requests, feedback, partnerships, press</p>
        </div>
      </div>

      <div class="flex items-start gap-4 px-5 py-4 rounded-xl border border-surface-200 dark:border-surface-800 bg-surface-50 dark:bg-surface-900">
        <span class="text-xl mt-0.5">🐛</span>
        <div>
          <p class="text-xs font-bold text-surface-700 dark:text-surface-300 mb-1">Bug reports</p>
          <a href="mailto:hello@neetab.com?subject=Bug Report" class="text-sm text-brand-500 font-medium hover:underline">hello@neetab.com</a>
          <p class="text-xs text-surface-400 mt-1">Tell us what tool, what happened, and what browser you're using</p>
        </div>
      </div>

      <div class="flex items-start gap-4 px-5 py-4 rounded-xl border border-surface-200 dark:border-surface-800 bg-surface-50 dark:bg-surface-900">
        <span class="text-xl mt-0.5">💡</span>
        <div>
          <p class="text-xs font-bold text-surface-700 dark:text-surface-300 mb-1">Tool requests</p>
          <a href="mailto:hello@neetab.com?subject=Tool Request" class="text-sm text-brand-500 font-medium hover:underline">hello@neetab.com</a>
          <p class="text-xs text-surface-400 mt-1">Have a tool idea? We genuinely consider every suggestion</p>
        </div>
      </div>
    </div>

    <p class="text-xs text-surface-400 mt-8 text-center">
      Neetab is built and maintained by a small team. We appreciate your patience.
    </p>
  </div>

  <Footer slot="footer" />
</Layout>
