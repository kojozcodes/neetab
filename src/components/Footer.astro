---
import { categories } from '../data/tools';
---

<footer class="border-t border-surface-200 dark:border-surface-800 mt-16">
  <div class="max-w-4xl mx-auto px-5 py-10">
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6 mb-8">
      {categories.map(cat => (
        <div>
          <h3 class="text-xs font-bold text-surface-700 dark:text-surface-300 mb-2">
            {cat.emoji} {cat.name}
          </h3>
          <ul class="space-y-1">
            {cat.tools.map(tool => (
              <li>
                <a href={`/tools/${tool.slug}`} class="text-[11px] text-surface-500 hover:text-brand-500 transition-colors">
                  {tool.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-6 border-t border-surface-200 dark:border-surface-800">
      <div class="flex items-center gap-2">
        <svg width="20" height="20" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
          <defs><linearGradient id="fg" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#FF6B35"/><stop offset="100%" stop-color="#FF8F65"/></linearGradient></defs>
          <rect width="32" height="32" rx="8" fill="url(#fg)"/>
          <circle cx="9.5" cy="9.5" r="2.8" fill="rgba(255,255,255,0.95)"/><circle cx="16" cy="9.5" r="2.8" fill="rgba(255,255,255,0.95)"/><circle cx="22.5" cy="9.5" r="2.8" fill="rgba(255,255,255,0.95)"/>
          <circle cx="9.5" cy="16" r="2.8" fill="rgba(255,255,255,0.95)"/><circle cx="16" cy="16" r="2.8" fill="rgba(255,255,255,0.95)"/><circle cx="22.5" cy="16" r="2.8" fill="rgba(255,255,255,0.95)"/>
          <circle cx="9.5" cy="22.5" r="2.8" fill="rgba(255,255,255,0.95)"/><circle cx="16" cy="22.5" r="2.8" fill="rgba(255,255,255,0.95)"/><circle cx="22.5" cy="22.5" r="2.8" fill="rgba(255,255,255,0.95)"/>
        </svg>
        <span class="text-xs text-surface-500">
          <span class="font-bold text-surface-700 dark:text-surface-300">Nee</span><span class="font-bold text-brand-500">tab</span> | Neat tools. One tab.
        </span>
      </div>
      <div class="text-[11px] text-surface-400">
        Free to use · Privacy-first · No sign-up required
      </div>
      <div class="flex items-center gap-3 text-[11px]">
        <a href="/about" class="text-surface-400 hover:text-brand-500 transition-colors">About</a>
        <a href="/contact" class="text-surface-400 hover:text-brand-500 transition-colors">Contact</a>
        <a href="/privacy" class="text-surface-400 hover:text-brand-500 transition-colors">Privacy</a>
        <a href="/terms" class="text-surface-400 hover:text-brand-500 transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>